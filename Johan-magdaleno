<!DOCTYPE html><html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Luxury Perfumes</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
<style>
body{margin:0;font-family:'Poppins',sans-serif;background:#0f0f0f;color:#fff}
header{display:flex;justify-content:space-between;align-items:center;padding:20px 40px;background:#000;position:sticky;top:0}
nav a{color:#fff;margin-left:15px;text-decoration:none}
.hero{height:70vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;background:linear-gradient(rgba(0,0,0,.6),rgba(0,0,0,.9)),url('https://images.unsplash.com/photo-1592945403244-b3fbafd7f539') center/cover}
.hero h2{font-size:40px}
.hero button{padding:10px 20px;background:gold;border:none;border-radius:20px;cursor:pointer}
.section{padding:40px;text-align:center}
input{padding:10px;width:250px;border-radius:20px;border:none;margin-bottom:20px}
.products{display:flex;flex-wrap:wrap;justify-content:center;gap:15px}
.card{background:#1a1a1a;border-radius:10px;width:220px;padding:10px}
.card img{width:100%;height:200px;object-fit:cover}
.price{color:gold;font-weight:bold}
button{background:gold;border:none;padding:8px 12px;border-radius:15px;cursor:pointer}
#cart{position:fixed;right:10px;top:80px;background:#000;padding:10px;border-radius:10px;width:200px}
.whatsapp{position:fixed;bottom:20px;right:20px;background:#25D366;color:white;padding:15px;border-radius:50%;text-decoration:none;font-size:20px}
</style>
</head>
<body><header>
<h1>Luxury Perfumes</h1>
<nav>
<a href="#">Inicio</a>
<a href="#productos">Perfumes</a>
</nav>
</header><section class="hero">
<h2>Perfumes que definen tu estilo</h2>
<button onclick="document.getElementById('productos').scrollIntoView()">Ver colección</button>
</section><div id="cart">
<h3>🛒 Carrito</h3>
<ul id="cart-items"></ul>
<p id="total">Total: $0</p>
</div><section id="productos" class="section">
<h2>Catálogo</h2>
<input type="text" placeholder="Buscar perfume..." onkeyup="buscar(this.value)">
<div class="products"><!-- Precios organizados --><div class="card"><img src="https://source.unsplash.com/400x400/?versace,eros,perfume"><h3>Versace Eros</h3><p class="price">$1,900 MXN</p><button onclick="add('Versace Eros',1900)">Comprar</button></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?jean-paul-gaultier,perfume"><h3>Jean Paul Gaultier Le Male</h3><p class="price">$1,800 MXN</p><button onclick="add('Le Male',1800)">Comprar</button></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?212,carolina,herrera,perfume"><h3>212 Men Carolina Herrera</h3><p class="price">$1,700 MXN</p><button onclick="add('212 Men',1700)">Comprar</button></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?nautica,perfume"><h3>Nautica Voyage</h3><p class="price">$700 MXN</p><button onclick="add('Nautica Voyage',700)">Comprar</button></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?phantom,perfume"><h3>Paco Rabanne Phantom</h3><p class="price">$2,000 MXN</p><button onclick="add('Phantom',2000)">Comprar</button></div><div class="card"><img src="https://source.unsplash.com/400x400/?dior,sauvage,perfume"><h3>Dior Sauvage</h3><p class="price">$2,200 MXN</p><button onclick="add('Dior Sauvage',2200)">Comprar</button></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?chanel,bleu,perfume"><h3>Bleu de Chanel</h3><p class="price">$2,300 MXN</p><button onclick="add('Bleu Chanel',2300)">Comprar</button></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?invictus,perfume"><h3>Invictus – Paco Rabanne</h3><p class="price">$1,900 MXN</p><button onclick="add('Invictus',1900)">Comprar</button></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?one-million,perfume"><h3>One Million – Paco Rabanne</h3><p class="price">$2,000 MXN</p><button onclick="add('One Million',2000)">Comprar</button></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?giorgio-armani,perfume"><h3>Acqua di Giò – Giorgio Armani</h3><p class="price">$2,100 MXN</p><button onclick="add('Acqua di Gio',2100)">Comprar</button></div><div class="card"><img src="https://source.unsplash.com/400x400/?hugo-boss,perfume"><h3>Hugo Boss Bottled</h3><p class="price">$1,700 MXN</p><button onclick="add('Boss Bottled',1700)">Comprar</button></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?montblanc,perfume"><h3>Montblanc Explorer</h3><p class="price">$1,600 MXN</p><button onclick="add('Explorer',1600)">Comprar</button></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?azzaro,perfume"><h3>Azzaro Wanted</h3><p class="price">$1,800 MXN</p><button onclick="add('Azzaro',1800)">Comprar</button></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?valentino,perfume"><h3>Valentino Uomo</h3><p class="price">$2,200 MXN</p><button onclick="add('Valentino',2200)">Comprar</button></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?jimmy-choo,perfume"><h3>Jimmy Choo Man</h3><p class="price">$1,600 MXN</p><button onclick="add('Jimmy Choo',1600)">Comprar</button></div><div class="card"><img src="https://source.unsplash.com/400x400/?issey-miyake,perfume"><h3>Issey Miyake L'Eau d'Issey</h3><p class="price">$1,700 MXN</p><button onclick="add('Issey',1700)">Comprar</button></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?perry-ellis,perfume"><h3>Perry Ellis 360 Red</h3><p class="price">$900 MXN</p><button onclick="add('Perry Ellis',900)">Comprar</button></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?armaf,perfume"><h3>Armaf Club de Nuit Intense</h3><p class="price">$1,000 MXN</p><button onclick="add('Armaf',1000)">Comprar</button></div>
