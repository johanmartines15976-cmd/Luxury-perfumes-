<div class="card"><img src="https://source.unsplash.com/400x400/?nautica,blue,perfume"><h3>Nautica Blue</h3><p class="price">$700 MXN</p><button onclick="add('Nautica Blue',700)">Comprar</button></div></div>
</section><a class="whatsapp" href="https://wa.me/526861119956" target="_blank">💬</a>

<script>
let total=0
function add(nombre,precio){
let li=document.createElement('li')
li.textContent=nombre+" - $"+precio
 document.getElementById('cart-items').appendChild(li)
 total+=precio
 document.getElementById('total').textContent="Total: $"+total
}
function buscar(texto){
let items=document.querySelectorAll('.card')
items.forEach(i=>{
 let nombre=i.querySelector('h3').textContent.toLowerCase()
 i.style.display=nombre.includes(texto.toLowerCase())?'block':'none'
})
}
</script></body>
